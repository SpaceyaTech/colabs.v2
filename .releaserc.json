{
  "$schema": "https://json.schemastore.org/semantic-release.json",

  "branches": ["main"],

  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "angular",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "release": false },
          { "type": "style", "release": false },
          { "type": "test", "release": false },
          { "type": "chore", "release": false },
          { "breaking": true, "release": "major" }
        ]
      }
    ],

    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "angular",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "Features" },
            { "type": "fix", "section": "Bug fixes" },
            { "type": "perf", "section": "Performance" },
            { "type": "refactor", "section": "Refactoring", "hidden": false },
            { "type": "docs", "section": "Documentation", "hidden": false },
            { "type": "chore", "section": "Maintenance", "hidden": true },
            { "type": "style", "hidden": true },
            { "type": "test", "hidden": true }
          ]
        }
      }
    ],

    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to Colabs are documented here.\nGenerated automatically from [Conventional Commits](https://www.conventionalcommits.org/)."
      }
    ],

    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],

    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],

    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/**",
            "label": "Production build (dist)"
          }
        ],
        "addReleases": "bottom",
        "successComment": "This PR is included in version ${nextRelease.version}.\n\nSee the [release notes](${releases[0].url}) for what changed.",
        "failComment": "The release from this PR failed. A maintainer will investigate.\n\nSee the [failed workflow run](${process.env.GITHUB_SERVER_URL}/${process.env.GITHUB_REPOSITORY}/actions) for details.",
        "releasedLabels": ["released"]
      }
    ]
  ]
}
